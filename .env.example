# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/laif

# JWT secret for auth tokens (generate a random 64-char string)
JWT_SECRET=your-secret-here

# OpenRouter API key (for AI Brief + Chat)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Web Push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# Firebase Admin (optional — for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# PostHook (optional — for scheduled notifications)
POSTHOOK_API_KEY=

# SendGrid (optional — for email notifications)
SENDGRID_API_KEY=
